    private void MarkCartographicProjectionClean()
    {
        cleanCartographicProjectionSnapshot_ = BuildCartographicProjectionDirtySnapshot();
    }

    private bool HasUnsavedCartographicProjectionChanges()
    {
        return cleanCartographicProjectionSnapshot_ != null &&
            !string.Equals(cleanCartographicProjectionSnapshot_, BuildCartographicProjectionDirtySnapshot(), StringComparison.Ordinal);
    }

    private string BuildCartographicProjectionDirtySnapshot()
    {
        return JsonSerializer.Serialize(new
        {
            CartographicProjectionId = CurrentCartographicProjection?.MetaInfo?.ID,
            Name = name,
            Description = descr,
            GeodeticDatumId = geodeticDatum?.MetaInfo?.ID,
            ProjectionType = cartographicProjectionType?.Projection,
            Zone = zone,
            NorthSouth = northSouth,
            LatitudeOrigin = latitudeOrigin,
            Latitude1 = latitude1,
            Latitude2 = latitude2,
            LatitudeTrueScale = latitudeTrueScale,
            LongitudeOrigin = longitudeOrigin,
            Scaling = scaling,
            FalseEasting = falseEasting,
            FalseNorthing = falseNorthing,
            IsHyperbolic = isHyperbolic,
            ProjectionHeight = projectionHeight,
            HeightViewPoint = heightViewPoint,
            Sweep = sweep,
            AzimuthCentralLine = azimuthCentralLine,
            Weight = weight,
            Landsat = landsat,
            Path = path,
            Alpha = alpha,
            Gamma = gamma,
            Longitude1 = longitude1,
            Longitude2 = longitude2,
            LongitudeCentralPoint = longitudeCentralPoint,
            NoOffset = noOffset,
            NoRotation = noRotation,
            AreaNormalizationTransform = areaNormalizationTransform,
            PegLatitude = pegLatitude,
            PegLongitude = pegLongitude,
            PegHeading = pegHeading,
            N = n,
            Q = q
        });
    }

    private async Task<bool> ConfirmCloseWithoutSavingAsync()
    {
        bool? result = await DialogService.ShowMessageBox(
            "Unsaved changes",
            "Some changes have not been saved. Close without saving?",
            yesText: "Close without saving",
            cancelText: "Stay",
            options: new DialogOptions
            {
                CloseOnEscapeKey = true,
                FullWidth = false,
                MaxWidth = MaxWidth.ExtraSmall
            });

        return result == true;
    }
